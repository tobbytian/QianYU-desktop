{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "QianYU TTS",
  "version": "1.0.0",
  "identifier": "com.qianyu.tts",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QianYU TTS - 文本转语音工具",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/qianyu-server",
      "binaries/qianyu-server-cuda"
    ],
    "resources": [
      "models/*",
      "bin/tools/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"]
      }
    }
  }
}
